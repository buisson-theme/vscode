  "tokenColors": [
    {
      "name": "Comments",
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": { "foreground": "#5c5640", "fontStyle": "italic" }
    },
    {
      "name": "Keywords — hibiscus",
      "scope": [
        "keyword", "keyword.control", "keyword.operator.logical",
        "keyword.other", "storage", "storage.type", "storage.modifier",
        "constant.language", "support.type.primitive"
      ],
      "settings": { "foreground": "#c02040" }
    },
    {
      "name": "Functions — sage",
      "scope": ["entity.name.function", "entity.name.method", "support.function", "variable.function"],
      "settings": { "foreground": "#387008" }
    },
    {
      "name": "Types & Classes — river moss",
      "scope": [
        "entity.name.type", "entity.name.class", "entity.name.namespace",
        "support.class", "support.type", "entity.name.exception", "entity.name.interface"
      ],
      "settings": { "foreground": "#096868" }
    },
    {
      "name": "Strings — ochre",
      "scope": ["string", "string.quoted", "string.interpolated", "constant.character"],
      "settings": { "foreground": "#a04810" }
    },
    {
      "name": "Numbers — slate sky",
      "scope": ["constant.numeric", "constant.other.color"],
      "settings": { "foreground": "#1860a8" }
    },
    {
      "name": "Operators & Decorators — thistle",
      "scope": [
        "keyword.operator", "keyword.operator.assignment", "keyword.operator.comparison",
        "punctuation.definition.decorator", "storage.type.annotation"
      ],
      "settings": { "foreground": "#6028a8" }
    },
    {
      "name": "Variables — fg0",
      "scope": ["variable", "variable.other"],
      "settings": { "foreground": "#1a1208" }
    },
    {
      "name": "Parameters — italic",
      "scope": ["variable.parameter"],
      "settings": { "foreground": "#1a1208", "fontStyle": "italic" }
    },
    {
      "name": "Punctuation — fg1",
      "scope": ["punctuation", "meta.brace", "meta.bracket", "punctuation.accessor"],
      "settings": { "foreground": "#373520" }
    },
    {
      "name": "HTML/JSX Tags — river moss",
      "scope": ["entity.name.tag"],
      "settings": { "foreground": "#096868" }
    },
    {
      "name": "HTML Attributes — river moss",
      "scope": ["entity.other.attribute-name"],
      "settings": { "foreground": "#096868" }
    },
    {
      "name": "CSS Properties",
      "scope": ["support.type.property-name.css", "meta.property-name"],
      "settings": { "foreground": "#387008" }
    },
    {
      "name": "JSON Keys",
      "scope": ["support.type.property-name.json", "meta.object-literal.key"],
      "settings": { "foreground": "#387008" }
    },
    {
      "name": "Markdown Headings — sage bold",
      "scope": ["markup.heading"],
      "settings": { "foreground": "#387008", "fontStyle": "bold" }
    },
    {
      "name": "Markdown Bold — hibiscus",
      "scope": ["markup.bold"],
      "settings": { "foreground": "#c02040", "fontStyle": "bold" }
    },
    {
      "name": "Markdown Italic — ochre",
      "scope": ["markup.italic"],
      "settings": { "foreground": "#a04810", "fontStyle": "italic" }
    },
    {
      "name": "Markdown Inline Code — muted",
      "scope": ["markup.inline.raw"],
      "settings": { "foreground": "#5c5640" }
    },
    {
      "name": "Markdown Links — slate",
      "scope": ["markup.underline.link"],
      "settings": { "foreground": "#1860a8" }
    },
    {
      "name": "Markdown list marker — moss",
      "scope": ["punctuation.definition.list.begin.markdown"],
      "settings": { "foreground": "#096868" }
    }
  ],

  "semanticTokenColors": {
    "function": "#387008",
    "method": "#387008",
    "class": "#096868",
    "type": "#096868",
    "interface": "#096868",
    "parameter": { "foreground": "#1a1208", "italic": true },
    "variable.readonly": "#1860a8",
    "keyword": "#c02040",
    "string": "#a04810",
    "number": "#1860a8",
    "operator": "#6028a8",
    "decorator": "#6028a8",
    "comment": { "foreground": "#5c5640", "italic": true },
    "namespace": "#096868",
    "property": "#1a1208"
  }
}
